# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database - Use PostgreSQL in production
DATABASE_URL=postgres://user:password@localhost:5432/pharmastream

# CORS Settings - Specify your frontend domain(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com,https://www.yourdomain.com

# Security settings (optional, defaults to True in production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Stripe Payment Settings
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# M-Pesa Settings
MPESA_SHORTCODE=174379
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback/

# Airtel Money Settings
AIRTEL_CLIENT_ID=your_airtel_id
AIRTEL_CLIENT_SECRET=your_airtel_secret

# Google OAuth - Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

